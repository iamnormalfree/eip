// ABOUTME: EIP Steel Thread smoke test runner
// ABOUTME: Executes and validates all critical smoke tests

import { describe, it, expect, beforeAll, afterAll } from '@jest/globals';
import { parallelRetrieve } from '../orchestrator/retrieval';
import { microAudit } from '../orchestrator/auditor';
import { BudgetEnforcer } from '../orchestrator/budget';
import { IntegrationTester, PerformanceTester, ContractValidator } from '../tests/utils/test-helpers';

// Smoke test configuration
const SMOKE_TEST_CONFIG = {
  performanceThresholds: {
    retrieval: { avgTime: 500, maxTime: 1000 },
    auditor: { avgTime: 1000, maxTime: 3000 }
  },
  budgetThresholds: {
    tokens: 2000,
    time: 30 // seconds
  },
  qualityThresholds: {
    minOverallScore: 60,
    maxCriticalErrors: 2
  }
};

const SMOKE_TEST_SCENARIOS = [
  {
    name: 'Financial Query Retrieval',
    query: 'Singapore property refinancing process',
    ip: 'framework@1.0.0',
    expectedDomain: 'finance'
  },
  {
    name: 'Housing Loan Information',
    query: 'HDB loan eligibility requirements',
    ip: 'process@1.0.0', 
    expectedDomain: 'housing'
  },
  {
    name: 'Bank Comparison Content',
    query: 'Bank loan versus HDB loan comparison',
    ip: 'comparative@1.0.0',
    expectedDomain: 'banking'
  }
];

describe('EIP Steel Thread Smoke Tests', () => {
  let testResults: any[] = [];
  let overallBudget: BudgetEnforcer;

  beforeAll(() => {
    overallBudget = new BudgetEnforcer('MEDIUM');
    console.log('Starting EIP Steel Thread smoke tests...');
  });

  afterAll(() => {
    const report = IntegrationTester.generateTestReport(testResults);
    console.log(report);
    
    const budgetReport = BudgetTester.generateBudgetReport(overallBudget.getTracker(), 'MEDIUM');
    console.log(budgetReport);
  });

  describe('Core Functionality Validation', () => {
    it('should retrieve content for all smoke test scenarios', async () => {
      for (const scenario of SMOKE_TEST_SCENARIOS) {
        const testStart = Date.now();
        
        try {
          const result = await parallelRetrieve({ query: scenario.query });
          const duration = Date.now() - testStart;
          
          // Basic contract validation
          const contractValidation = ContractValidator.validateRetrievalContract(result);
          expect(contractValidation.valid).toBe(true);
          
          // Performance validation
          expect(duration).toBeLessThan(SMOKE_TEST_CONFIG.performanceThresholds.retrieval.maxTime);
          
          // Content validation
          expect(result.candidates.length).toBeGreaterThan(0);
          expect(result.flags.bm25_used).toBe(true);
          expect(result.query_analysis.domain).toContain(scenario.expectedDomain);
          
          testResults.push({
            name: `Retrieval: ${scenario.name}`,
            success: true,
            metrics: { duration, success: true }
          });
          
        } catch (error) {
          testResults.push({
            name: `Retrieval: ${scenario.name}`,
            success: false,
            error: error.message,
            metrics: { duration: Date.now() - testStart, success: false }
          });
          
          throw error;
        }
      }
    });

    it('should audit generated content for quality compliance', async () => {
      for (const scenario of SMOKE_TEST_SCENARIOS) {
        const testStart = Date.now();
        
        try {
          // First retrieve content
          const retrievalResult = await parallelRetrieve({ query: scenario.query });
          
          if (retrievalResult.candidates.length > 0) {
            // Then audit the content
            const sampleContent = retrievalResult.candidates[0].content;
            const auditResult = await microAudit({ 
              draft: sampleContent, 
              ip: scenario.ip 
            });
            
            const duration = Date.now() - testStart;
            
            // Contract validation
            const contractValidation = ContractValidator.validateAuditorContract(auditResult);
            expect(contractValidation.valid).toBe(true);
            
            // Quality validation
            expect(auditResult.overall_score).toBeGreaterThanOrEqual(
              SMOKE_TEST_CONFIG.qualityThresholds.minOverallScore
            );
            
            // Count critical errors
            const criticalErrors = auditResult.tags.filter(tag => tag.severity === 'error');
            expect(criticalErrors.length).toBeLessThanOrEqual(
              SMOKE_TEST_CONFIG.qualityThresholds.maxCriticalErrors
            );
            
            testResults.push({
              name: `Audit: ${scenario.name}`,
              success: true,
              metrics: { duration, success: true },
              quality: { score: auditResult.overall_score, errors: criticalErrors.length }
            });
          }
          
        } catch (error) {
          testResults.push({
            name: `Audit: ${scenario.name}`,
            success: false,
            error: error.message,
            metrics: { duration: Date.now() - testStart, success: false }
          });
          
          throw error;
        }
      }
    });
  });

  describe('Performance Validation', () => {
    it('should meet performance benchmarks for retrieval', async () => {
      const testQuery = 'property refinancing process';
      
      const performanceResult = await PerformanceTester.measureFunction(
        () => parallelRetrieve({ query: testQuery }),
        { iterations: 5, warmupIterations: 2 }
      );
      
      const thresholds = SMOKE_TEST_CONFIG.performanceThresholds.retrieval;
      const performanceValidation = PerformanceTester.validatePerformanceThresholds(
        performanceResult,
        thresholds
      );
      
      expect(performanceValidation.valid).toBe(true);
      
      if (!performanceValidation.valid) {
        console.log('Performance violations:', performanceValidation.violations);
      }
      
      testResults.push({
        name: 'Performance: Retrieval Benchmark',
        success: performanceValidation.valid,
        metrics: {
          duration: performanceResult.avgTime,
          success: performanceValidation.valid
        }
      });
    });

    it('should meet performance benchmarks for auditing', async () => {
      const testContent = `# Test Framework

## How It Works
1. Step one
2. Step two
3. Step three

## Example
This is an example application.`;
      
      const performanceResult = await PerformanceTester.measureFunction(
        () => microAudit({ draft: testContent, ip: 'framework@1.0.0' }),
        { iterations: 3, warmupIterations: 1 }
      );
      
      const thresholds = SMOKE_TEST_CONFIG.performanceThresholds.auditor;
      const performanceValidation = PerformanceTester.validatePerformanceThresholds(
        performanceResult,
        thresholds
      );
      
      expect(performanceValidation.valid).toBe(true);
      
      testResults.push({
        name: 'Performance: Auditor Benchmark',
        success: performanceValidation.valid,
        metrics: {
          duration: performanceResult.avgTime,
          success: performanceValidation.valid
        }
      });
    });
  });

  describe('Budget Compliance Validation', () => {
    it('should operate within budget constraints', async () => {
      overallBudget.startStage('generator');
      
      const budgetTest = await BudgetTester.validateBudgetCompliance(
        async () => {
          // Simulate a full generation workflow
          const retrievalResult = await parallelRetrieve({ 
            query: 'financial planning guide' 
          });
          
          if (retrievalResult.candidates.length > 0) {
            const auditResult = await microAudit({ 
              draft: retrievalResult.candidates[0].content,
              ip: 'framework@1.0.0'
            });
            return { retrievalResult, auditResult };
          }
          
          return { retrievalResult };
        },
        'MEDIUM',
        'generator',
        1500 // Estimated token usage
      );
      
      overallBudget.endStage('generator');
      
      expect(budgetTest.budgetCompliance).toBe(true);
      
      if (!budgetTest.budgetCompliance) {
        console.log('Budget violations:', budgetTest.violations);
      }
      
      testResults.push({
        name: 'Budget Compliance',
        success: budgetTest.budgetCompliance,
        metrics: {
          duration: 0,
          success: budgetTest.budgetCompliance
        }
      });
    });
  });

  describe('End-to-End Integration', () => {
    it('should complete full workflow for smoke test scenarios', async () => {
      const e2eResults = [];
      
      for (const scenario of SMOKE_TEST_SCENARIOS) {
        const e2eResult = await IntegrationTester.runEndToEndTest(
          scenario.query,
          scenario.ip
        );
        
        e2eResults.push({
          scenario: scenario.name,
          ...e2eResult
        });
        
        expect(e2eResult.success).toBe(true);
        
        if (!e2eResult.success) {
          console.log(`E2E failures for ${scenario.name}:`, e2eResult.errors);
        }
      }
      
      const allSuccessful = e2eResults.every(r => r.success);
      expect(allSuccessful).toBe(true);
      
      testResults.push({
        name: 'End-to-End Integration',
        success: allSuccessful,
        metrics: {
          duration: 0,
          success: allSuccessful
        }
      });
    });
  });

  describe('Contract Compliance', () => {
    it('should satisfy all component contracts', async () => {
      const contractTests = [
        {
          name: 'Retrieval Contract',
          test: async () => {
            const result = await parallelRetrieve({ query: 'test query' });
            return ContractValidator.validateRetrievalContract(result);
          }
        },
        {
          name: 'Auditor Contract',
          test: async () => {
            const result = await microAudit({ 
              draft: 'Test content', 
              ip: 'framework@1.0.0' 
            });
            return ContractValidator.validateAuditorContract(result);
          }
        }
      ];
      
      for (const contractTest of contractTests) {
        const validation = await contractTest.test();
        
        expect(validation.valid).toBe(true);
        
        if (!validation.valid) {
          console.log(`${contractTest.name} violations:`, validation.violations);
        }
        
        testResults.push({
          name: `Contract: ${contractTest.name}`,
          success: validation.valid,
          metrics: {
            duration: 0,
            success: validation.valid
          }
        });
      }
    });
  });

  describe('Quality Gates Validation', () => {
    it('should pass all quality gates for Steel Thread', async () => {
      const qualityGateResults = [];
      
      for (const scenario of SMOKE_TEST_SCENARIOS) {
        // IP Invariant Gate
        const retrievalResult = await parallelRetrieve({ query: scenario.query });
        const ipInvariantPassed = retrievalResult.candidates.length > 0;
        
        // Compliance Gate (mock for now)
        const compliancePassed = true; // Would check actual compliance rules
        
        // Performance Gate
        const performancePassed = retrievalResult.flags.retrieval_time_ms < 1000;
        
        // Integration Gate
        const integrationPassed = retrievalResult.flags.bm25_used;
        
        qualityGateResults.push({
          scenario: scenario.name,
          ipInvariantPassed,
          compliancePassed,
          performancePassed,
          integrationPassed,
          allPassed: ipInvariantPassed && compliancePassed && performancePassed && integrationPassed
        });
      }
      
      const allQualityGatesPassed = qualityGateResults.every(r => r.allPassed);
      expect(allQualityGatesPassed).toBe(true);
      
      qualityGateResults.forEach(result => {
        testResults.push({
          name: `Quality Gates: ${result.scenario}`,
          success: result.allPassed,
          metrics: {
            duration: 0,
            success: result.allPassed
          }
        });
      });
    });
  });
});

// Performance regression detection
describe('Performance Regression Detection', () => {
  it('should detect performance regressions in critical paths', async () => {
    const regressionTests = [
      {
        name: 'BM25 Retrieval Performance',
        fn: () => parallelRetrieve({ query: 'regression test query' }),
        baselineAvgTime: 300,
        tolerance: 0.5 // 50% tolerance
      },
      {
        name: 'Micro-Auditor Performance',
        fn: () => microAudit({ draft: 'Regression test content', ip: 'framework@1.0.0' }),
        baselineAvgTime: 800,
        tolerance: 0.5
      }
    ];
    
    for (const regressionTest of regressionTests) {
      const performanceResult = await PerformanceTester.measureFunction(
        regressionTest.fn,
        { iterations: 3, warmupIterations: 1 }
      );
      
      const maxAcceptableTime = regressionTest.baselineAvgTime * (1 + regressionTest.tolerance);
      
      expect(performanceResult.avgTime).toBeLessThan(maxAcceptableTime);
      
      console.log(`${regressionTest.name}: ${performanceResult.avgTime}ms (baseline: ${regressionTest.baselineAvgTime}ms)`);
    }
  });
});
