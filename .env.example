# EIP Environment Configuration Example
# Copy this file to .env.local and fill in your values

# Redis Configuration (for queue mode)
REDIS_URL=redis://localhost:6379

# Queue Mode (enable for async processing)
EIP_QUEUE_MODE=enabled

# Queue Strict Mode - Set to true in production to fail fast (no fallback to direct execution)
# When true, queue submission/processing failures will NOT fallback to direct execution
# Default: not set (fallback enabled for local dev)
# EIP_QUEUE_STRICT=true

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Keys (server-side only - never expose)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SERVICE_KEY=your-service-key

# Optional: Override default queue settings
# EIP_QUEUE_CONCURRENCY=5
# EIP_QUEUE_MAX_RETRIES=3
