{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@maf/*": ["lib/maf/*"]
    },
    "types": ["node", "jest"]
  },
  "include": [
    "lib/maf/**/*",
    "maf/scripts/maf/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
