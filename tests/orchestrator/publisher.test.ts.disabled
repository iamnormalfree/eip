// ABOUTME: Content publishing testing for EIP Steel Thread
// ABOUTME: Validates content publication workflow, compliance verification, and database operations

import { describe, it, expect, beforeEach, afterEach } from '@jest/globals';

describe('Content Publisher System', () => {
  const testContent = {
    id: 'test-content-123',
    ip_type: 'framework',
    ip_version: '1.0.0',
    title: 'Strategic Planning Framework',
    body: `This framework provides systematic approach to strategic planning.

## Overview
## How It Works
1. Assessment phase
2. Planning phase
3. Implementation phase
4. Monitoring phase

## Example
Technology companies use this for product roadmap planning.`,
    brief: 'Create a strategic planning framework for technology companies',
    persona: 'strategy-consultant',
    funnel: 'enterprise',
    tier: 'HEAVY',
    content: `# Strategic Planning Framework

## Overview
This framework provides systematic approach to strategic planning.

## How It Works
1. Assessment phase
2. Planning phase  
3. Implementation phase
4. Monitoring phase

## Example
Technology companies use this for product roadmap planning.

## Compliance
Follows MAS guidelines for corporate governance.`,
    
    compliance_tags: {
      domains: ['mas.gov.sg'],
      financial_claims_sourced: true,
      legal_disclaimers: true,
      risk_warnings: true
    },
    
    provenance: {
      generated_by: 'eip-orchestrator',
      generation_timestamp: '2025-01-14T10:30:00Z',
      retrieval_sources: ['mas-guidelines-001', 'corporate-governance-002'],
      audit_trail: {
        auditor_score: 95,
        repair_applied: false,
        human_review_required: false
      }
    }
  };

  describe('Content Publication Workflow', () => {
    beforeEach(() => {
      jest.mock('../../orchestrator/publisher', () => ({
        publishArtifact: jest.fn(),
        MDXRenderer: jest.fn().mockImplementation(() => ({
          render: jest.fn()
        }))
      }));
    });

    it('should publish content successfully with full validation', async () => {
      const { publishArtifact } = await import('../../orchestrator/publisher');
      (publishArtifact as jest.Mock).mockResolvedValue({
        success: true,
        content_id: testContent.id,
        publication_timestamp: '2025-01-14T11:00:00Z',
        database_record: {
          id: testContent.id,
          status: 'published',
          published_at: '2025-01-14T11:00:00Z',
          version: 1,
          compliance_verified: true,
          audit_passed: true
        },
        validation_results: {
          structure_valid: true,
          compliance_valid: true,
          provenance_complete: true,
          quality_score_acceptable: true
        },
        metrics: {
          publication_time_ms: 250,
          database_write_time_ms: 120,
          validation_time_ms: 80
        }
      });

      const result = await publishArtifact({
        draft: testContent.content,
        ip: testContent.ip_type,
        audit: {
          tags: [{ tag: 'quality', severity: 'info' }],
          overall_score: 95
        },
        retrieval: {
          flags: {},
          candidates: []
        },
        metadata: {
          brief: testContent.brief,
          persona: testContent.persona,
          funnel: testContent.funnel,
          tier: testContent.tier
        }
      });

      expect(result.mdx).toContain('Strategic Planning Framework');
      expect(result.jsonld).toBeDefined();
      expect(result.ledger.ip_used).toBe('Framework');
      expect(result.ledger.ip_invariants.required).toBeDefined();
      expect(result.ledger.compliance_sources).toBeDefined();
    });

    it('should reject content that fails validation', async () => {
      const { publishArtifact } = await import('../../orchestrator/publisher');
      (publishArtifact as jest.Mock).mockResolvedValue({
        success: false,
        content_id: testContent.id,
        rejection_reason: 'Content failed compliance validation',
        validation_failures: [
          'Financial claims not properly sourced',
          'Missing MAS domain references',
          'Incomplete provenance trail'
        ],
        suggestions: [
          'Add proper source citations for financial claims',
          'Include MAS guidelines references',
          'Complete generation audit trail'
        ]
      });

      const invalidContent = {
        ...testContent,
        compliance_tags: {
          domains: [],
          financial_claims_sourced: false,
          legal_disclaimers: false
        },
        provenance: {
          generated_by: 'unknown',
          generation_timestamp: null
        }
      };

      const result = await publishArtifact({
        content: invalidContent,
        publication_options: {
          validate_before_publish: true
        }
      });

      expect(result.success).toBe(false);
      expect(result.validation_failures.length).toBeGreaterThan(0);
      expect(result.suggestions.length).toBeGreaterThan(0);
    });
  });

  describe('Publication Readiness Validation', () => {
    it('should validate content structure requirements', async () => {
      const { validatePublicatioReadiness } = await import('../../orchestrator/publisher');
      (validatePublicatioReadiness as jest.Mock).mockResolvedValue({
        ready: true,
        validation_checks: {
          structure: {
            valid: true,
            required_sections_present: ['overview', 'mechanism', 'examples'],
            section_validation: {
              overview: { present: true, word_count: 45 },
              mechanism: { present: true, step_count: 4 },
              examples: { present: true, example_count: 1 }
            }
          },
          compliance: {
            valid: true,
            domains_verified: ['mas.gov.sg'],
            financial_claims_sourced: true,
            legal_disclaimers_present: true
          },
          provenance: {
            valid: true,
            complete_trail: true,
            all_required_fields: true,
            timestamp_valid: true
          }
        },
        overall_score: 95
      });

      const validation = await validatePublicatioReadiness(testContent);

      expect(validation.ready).toBe(true);
      expect(validation.validation_checks.structure.valid).toBe(true);
      expect(validation.validation_checks.compliance.valid).toBe(true);
      expect(validation.validation_checks.provenance.valid).toBe(true);
      expect(validation.overall_score).toBeGreaterThan(90);
    });

    it('should detect missing required elements', async () => {
      const { validatePublicatioReadiness } = await import('../../orchestrator/publisher');
      (validatePublicatioReadiness as jest.Mock).mockResolvedValue({
        ready: false,
        validation_checks: {
          structure: {
            valid: false,
            missing_sections: ['compliance'],
            section_validation: {
              overview: { present: true, word_count: 45 },
              mechanism: { present: true, step_count: 4 },
              examples: { present: false },
              compliance: { present: false }
            }
          },
          compliance: {
            valid: false,
            missing_elements: ['mas_domain_references', 'risk_warnings'],
            domains_verified: []
          },
          provenance: {
            valid: false,
            missing_fields: ['audit_trail', 'generation_timestamp'],
            incomplete_trail: true
          }
        },
        blocking_issues: [
          'Missing compliance section required for financial content',
          'No MAS domain references found',
          'Incomplete provenance trail'
        ],
        overall_score: 35
      });

      const incompleteContent = {
        ...testContent,
        content: `# Strategic Planning

## Overview
Basic overview here.`,
        
        compliance_tags: {
          domains: [],
          financial_claims_sourced: false,
          legal_disclaimers: false
        },
        
        provenance: {
          generated_by: 'eip-orchestrator'
        }
      };

      const validation = await validatePublicatioReadiness(incompleteContent);

      expect(validation.ready).toBe(false);
      expect(validation.validation_checks.structure.valid).toBe(false);
      expect(validation.blocking_issues.length).toBeGreaterThan(0);
      expect(validation.overall_score).toBeLessThan(50);
    });
  });

  describe('Database Operations', () => {
    it('should store published content with correct metadata', async () => {
      const { publishArtifact } = await import('../../orchestrator/publisher');
      (publishArtifact as jest.Mock).mockResolvedValue({
        success: true,
        database_operations: {
          content_pieces_insert: {
            success: true,
            record_id: testContent.id,
            fields_stored: [
              'id', 'ip_type', 'ip_version', 'content', 'compliance_tags',
              'provenance', 'status', 'published_at', 'version'
            ]
          },
          generation_logs_insert: {
            success: true,
            log_id: 'log-456',
            metrics_recorded: [
              'generation_time_ms', 'tokens_used', 'quality_score',
              'repair_applied', 'human_review_required'
            ]
          },
          compliance_audit_insert: {
            success: true,
            audit_id: 'audit-789',
            compliance_data: [
              'domains_used', 'financial_claims_verified', 'legal_disclaimers_checked',
              'risk_warnings_present', 'audit_score'
            ]
          }
        },
        transaction_id: 'tx-123456789',
        data_integrity_verified: true
      });

      const result = await publishArtifact({
        content: testContent,
        publication_options: {
          record_in_all_tables: true,
          verify_data_integrity: true
        }
      });

      expect(result.database_operations.content_pieces_insert.success).toBe(true);
      expect(result.database_operations.generation_logs_insert.success).toBe(true);
      expect(result.database_operations.compliance_audit_insert.success).toBe(true);
      expect(result.data_integrity_verified).toBe(true);
    });

    it('should handle database transaction failures gracefully', async () => {
      const { publishArtifact } = await import('../../orchestrator/publisher');
      (publishArtifact as jest.Mock).mockResolvedValue({
        success: false,
        error_type: 'database_transaction_failure',
        error_details: {
          failed_operations: ['compliance_audit_insert'],
          error_message: 'Connection timeout during compliance audit insertion',
          rollback_successful: true,
          data_consistency_maintained: true
        },
        retry_possible: true,
        suggested_backoff_ms: 2000
      });

      const result = await publishArtifact({
        content: testContent,
        publication_options: {
          max_retries: 3,
          transaction_timeout_ms: 5000
        }
      });

      expect(result.success).toBe(false);
      expect(result.error_type).toBe('database_transaction_failure');
      expect(result.error_details.rollback_successful).toBe(true);
      expect(result.retry_possible).toBe(true);
    });
  });

  describe('Content Status Management', () => {
    it('should update content status through publication lifecycle', async () => {
      const { updateContentStatus } = await import('../../orchestrator/publisher');
      
      // Mock status update sequence
      (updateContentStatus as jest.Mock)
        .mockResolvedValueOnce({
          content_id: testContent.id,
          previous_status: null,
          new_status: 'draft',
          timestamp: '2025-01-14T10:30:00Z',
          updated_fields: ['status', 'created_at']
        })
        .mockResolvedValueOnce({
          content_id: testContent.id,
          previous_status: 'draft',
          new_status: 'validated',
          timestamp: '2025-01-14T10:45:00Z',
          updated_fields: ['status', 'validated_at']
        })
        .mockResolvedValueOnce({
          content_id: testContent.id,
          previous_status: 'validated',
          new_status: 'published',
          timestamp: '2025-01-14T11:00:00Z',
          updated_fields: ['status', 'published_at']
        });

      // Test status progression
      const draftStatus = await updateContentStatus(testContent.id, 'draft');
      expect(draftStatus.new_status).toBe('draft');

      const validatedStatus = await updateContentStatus(testContent.id, 'validated');
      expect(validatedStatus.new_status).toBe('validated');
      expect(validatedStatus.previous_status).toBe('draft');

      const publishedStatus = await updateContentStatus(testContent.id, 'published');
      expect(publishedStatus.new_status).toBe('published');
      expect(publishedStatus.previous_status).toBe('validated');
    });

    it('should handle invalid status transitions', async () => {
      const { updateContentStatus } = await import('../../orchestrator/publisher');
      (updateContentStatus as jest.Mock).mockResolvedValue({
        success: false,
        content_id: testContent.id,
        requested_status: 'published',
        current_status: 'draft',
        error: 'Invalid status transition: draft -> published requires validation step',
        allowed_transitions: [
          'draft -> validated',
          'validated -> published',
          'published -> archived'
        ],
        status_correction_required: true
      });

      const result = await updateContentStatus(testContent.id, 'published');

      expect(result.success).toBe(false);
      expect(result.error).toContain('Invalid status transition');
      expect(result.allowed_transitions).toContain('draft -> validated');
    });
  });

  describe('Compliance and Quality Assurance', () => {
    it('should verify compliance requirements before publication', async () => {
      const { publishArtifact } = await import('../../orchestrator/publisher');
      (publishArtifact as jest.Mock).mockResolvedValue({
        success: true,
        compliance_verification: {
          mas_domain_usage: {
            required: true,
            verified: true,
            domains_found: ['mas.gov.sg'],
            source_links_valid: true
          },
          financial_claims: {
            claims_detected: 2,
            claims_sourced: 2,
            conditional_language_used: 0,
            compliance_score: 100
          },
          legal_requirements: {
            disclaimers_present: true,
            risk_warnings_present: true,
            template_based: true,
            compliance_score: 95
          }
        },
        quality_metrics: {
          readability_score: 85,
          technical_accuracy: 92,
          completeness_score: 90,
          overall_quality: 89
        }
      });

      const result = await publishArtifact({
        content: testContent,
        publication_options: {
          compliance_check_level: 'strict',
          quality_threshold: 80
        }
      });

      expect(result.compliance_verification.mas_domain_usage.verified).toBe(true);
      expect(result.compliance_verification.financial_claims.compliance_score).toBe(100);
      expect(result.quality_metrics.overall_quality).toBeGreaterThan(80);
    });

    it('should enforce quality score thresholds', async () => {
      const { publishArtifact } = await import('../../orchestrator/publisher');
      (publishArtifact as jest.Mock).mockResolvedValue({
        success: false,
        rejection_reason: 'Content quality below publication threshold',
        quality_metrics: {
          readability_score: 65,
          technical_accuracy: 70,
          completeness_score: 45,
          overall_quality: 60
        },
        threshold_requirements: {
          minimum_overall_score: 75,
          minimum_readability: 70,
          minimum_completeness: 80,
          all_thresholds_met: false
        },
        failed_thresholds: [
          'Overall quality (60) below minimum (75)',
          'Completeness score (45) below minimum (80)'
        ],
        improvement_suggestions: [
          'Add more detailed examples',
          'Improve content structure and flow',
          'Expand mechanism explanation'
        ]
      });

      const lowQualityContent = {
        ...testContent,
        content: 'Basic content without details.'
      };

      const result = await publishArtifact({
        content: lowQualityContent,
        publication_options: {
          quality_threshold: 75
        }
      });

      expect(result.success).toBe(false);
      expect(result.quality_metrics.overall_quality).toBeLessThan(75);
      expect(result.failed_thresholds.length).toBeGreaterThan(0);
    });
  });

  describe('Performance and Scalability', () => {
    it('should publish content within performance budgets', async () => {
      const { publishArtifact } = await import('../../orchestrator/publisher');
      (publishArtifact as jest.Mock).mockImplementation(async () => {
        // Simulate publication processing time
        await new Promise(resolve => setTimeout(resolve, 150));
        return {
          success: true,
          performance_metrics: {
            total_publication_time_ms: 150,
            validation_time_ms: 45,
            database_write_time_ms: 85,
            compliance_check_time_ms: 20,
            within_budget: true
          }
        };
      });

      const startTime = Date.now();
      const result = await publishArtifact({
        content: testContent,
        publication_options: {
          performance_tracking: true
        }
      });
      const duration = Date.now() - startTime;

      expect(duration).toBeLessThan(1000); // Should complete within 1 second
      expect(result.performance_metrics.within_budget).toBe(true);
      expect(result.performance_metrics.total_publication_time_ms).toBeLessThan(500);
    });
  });

  afterEach(() => {
    jest.clearAllMocks();
  });
});
