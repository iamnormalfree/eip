// ABOUTME: Redis to Supabase migration script for EIP compliance validations
// ABOUTME: Migrates existing compliance validation data with zero data loss guarantee
// ABOUTME: Includes validation, rollback, and progress tracking

const { createClient } = require('@supabase/supabase-js');
const Redis = require('ioredis');

// Configuration
const SUPABASE_URL = process.env.NEXT_PUBLIC_SUPABASE_URL;
const SUPABASE_SERVICE_KEY = process.env.SUPABASE_SERVICE_ROLE_KEY || process.env.SUPABASE_SERVICE_KEY;
const REDIS_URL = process.env.REDIS_URL || 'redis://localhost:6379';

// Migration settings
const MIGRATION_BATCH_SIZE = parseInt(process.env.COMPLIANCE_MIGRATION_BATCH_SIZE || '100');
const DRY_RUN = process.env.COMPLIANCE_MIGRATION_DRY_RUN === 'true';
const BACKUP_REDIS_DATA = process.env.COMPLIANCE_MIGRATION_BACKUP === 'true';

if (!SUPABASE_URL || !SUPABASE_SERVICE_KEY) {
    console.error('❌ Missing required environment variables:');
    console.error('   NEXT_PUBLIC_SUPABASE_URL');
    console.error('   SUPABASE_SERVICE_ROLE_KEY or SUPABASE_SERVICE_KEY');
    process.exit(1);
}

// Initialize clients
let supabase, redis;

async function initializeClients() {
    try {
        console.log('🔗 Initializing database connections...');
        
        // Initialize Supabase client
        supabase = createClient(SUPABASE_URL, SUPABASE_SERVICE_KEY, {
            auth: {
                autoRefreshToken: false,
                persistSession: false
            }
        });
        
        // Initialize Redis client
        redis = new Redis(REDIS_URL);
        
        // Test connections
        await supabase.from('eip_jobs').select('count', { count: 'exact', head: true });
        await redis.ping();
        
        console.log('✅ Database connections initialized successfully');
        
    } catch (error) {
        console.error('❌ Failed to initialize database connections:', error.message);
        process.exit(1);
    }
}

async function closeConnections() {
    try {
        if (redis) {
            await redis.quit();
            console.log('🔌 Redis connection closed');
        }
        // Supabase client doesn't need explicit closing
        console.log('🔌 Supabase client released');
    } catch (error) {
        console.error('⚠️ Error closing connections:', error.message);
    }
}

// Data validation functions
function validateComplianceRecord(record) {
    const errors = [];
    
    if (!record.id || typeof record.id !== 'string') {
        errors.push('Invalid or missing id');
    }
    
    if (!record.job_id || typeof record.job_id !== 'string') {
        errors.push('Invalid or missing job_id');
    }
    
    if (record.compliance_score && (isNaN(record.compliance_score) || record.compliance_score < 0 || record.compliance_score > 100)) {
        errors.push('Invalid compliance_score (must be 0-100)');
    }
    
    if (record.violations_count && (isNaN(record.violations_count) || record.violations_count < 0)) {
        errors.push('Invalid violations_count (must be >= 0)');
    }
    
    if (record.processing_time_ms && (isNaN(record.processing_time_ms) || record.processing_time_ms < 0)) {
        errors.push('Invalid processing_time_ms (must be >= 0)');
    }
    
    try {
        if (record.evidence_summary && typeof record.evidence_summary === 'string') {
            JSON.parse(record.evidence_summary);
        }
    } catch (e) {
        errors.push('Invalid evidence_summary JSON');
    }
    
    try {
        if (record.compliance_report && typeof record.compliance_report === 'string') {
            JSON.parse(record.compliance_report);
        }
    } catch (e) {
        errors.push('Invalid compliance_report JSON');
    }
    
    return errors;
}

// Backup functions
async function backupRedisData(validationKeys) {
    if (!BACKUP_REDIS_DATA) {
        console.log('⏭️ Skipping Redis backup (BACKUP_REDIS_DATA=false)');
        return;
    }
    
    console.log(`💾 Creating Redis backup for ${validationKeys.length} records...`);
    
    const backupData = {};
    const backupKey = `compliance-migration-backup-${Date.now()}`;
    
    try {
        for (const key of validationKeys) {
            const data = await redis.hgetall(key);
            if (data && Object.keys(data).length > 0) {
                backupData[key] = data;
            }
        }
        
        // Store backup in Redis with longer TTL
        await redis.setex(backupKey, 86400 * 30, JSON.stringify(backupData)); // 30 days backup
        
        console.log(`✅ Redis backup created: ${backupKey}`);
        console.log(`   Backup contains ${Object.keys(backupData).length} records`);
        
        return backupKey;
        
    } catch (error) {
        console.error('❌ Failed to create Redis backup:', error.message);
        throw error;
    }
}

// Migration functions
async function scanRedisComplianceData() {
    console.log('🔍 Scanning Redis for compliance validation data...');
    
    try {
        const validationKeys = await redis.keys('compliance-validation:*');
        const jobKeys = await redis.keys('compliance-by-job:*');
        const artifactKeys = await redis.keys('compliance-by-artifact:*');
        
        console.log(`📊 Found in Redis:`);
        console.log(`   Validation records: ${validationKeys.length}`);
        console.log(`   Job indexes: ${jobKeys.length}`);
        console.log(`   Artifact indexes: ${artifactKeys.length}`);
        
        return {
            validationKeys,
            jobKeys,
            artifactKeys,
            totalRecords: validationKeys.length
        };
        
    } catch (error) {
        console.error('❌ Failed to scan Redis data:', error.message);
        throw error;
    }
}

async function migrateBatch(validationKeys, startIndex, batchSize) {
    const endIndex = Math.min(startIndex + batchSize, validationKeys.length);
    const batchKeys = validationKeys.slice(startIndex, endIndex);
    
    console.log(`📦 Processing batch ${Math.floor(startIndex / batchSize) + 1}: records ${startIndex + 1}-${endIndex}`);
    
    const migrationResults = {
        processed: 0,
        successful: 0,
        failed: 0,
        errors: []
    };
    
    for (const key of batchKeys) {
        try {
            migrationResults.processed++;
            
            // Get record from Redis
            const redisData = await redis.hgetall(key);
            
            if (!redisData || Object.keys(redisData).length === 0) {
                console.warn(`⚠️ Empty record found: ${key}`);
                continue;
            }
            
            // Validate record
            const validationErrors = validateComplianceRecord(redisData);
            if (validationErrors.length > 0) {
                console.warn(`⚠️ Validation failed for ${key}:`, validationErrors.join(', '));
                migrationResults.errors.push({
                    key,
                    errors: validationErrors,
                    data: redisData
                });
                continue;
            }
            
            // Transform data for Supabase
            const supabaseRecord = {
                id: redisData.id,
                job_id: redisData.job_id,
                artifact_id: redisData.artifact_id || null,
                compliance_status: redisData.compliance_status || 'pending',
                compliance_score: parseInt(redisData.compliance_score) || 0,
                violations_count: parseInt(redisData.violations_count) || 0,
                authority_level: redisData.authority_level || 'low',
                processing_tier: redisData.processing_tier || 'LIGHT',
                processing_time_ms: parseInt(redisData.processing_time_ms) || 0,
                evidence_summary: redisData.evidence_summary ? 
                    (typeof redisData.evidence_summary === 'string' ? JSON.parse(redisData.evidence_summary) : redisData.evidence_summary) : {},
                validation_level: redisData.validation_level || 'standard',
                content_length: parseInt(redisData.content_length) || 0,
                sources_count: parseInt(redisData.sources_count) || 0,
                correlation_id: redisData.correlation_id || null,
                validation_timestamp: redisData.validation_timestamp || new Date().toISOString(),
                compliance_report: redisData.compliance_report ? 
                    (typeof redisData.compliance_report === 'string' ? JSON.parse(redisData.compliance_report) : redisData.compliance_report) : {}
            };
            
            if (DRY_RUN) {
                console.log(`🔍 [DRY RUN] Would migrate: ${key} -> ${supabaseRecord.id}`);
                migrationResults.successful++;
                continue;
            }
            
            // Insert into Supabase
            const { data, error } = await supabase
                .from('eip_compliance_validations')
                .insert(supabaseRecord)
                .select()
                .single();
            
            if (error) {
                // Check if it's a duplicate key error
                if (error.code === '23505') {
                    console.log(`ℹ️ Record already exists in Supabase: ${supabaseRecord.id}`);
                    migrationResults.successful++;
                } else {
                    console.error(`❌ Failed to insert ${key}:`, error.message);
                    migrationResults.errors.push({
                        key,
                        error: error.message,
                        data: supabaseRecord
                    });
                    migrationResults.failed++;
                }
            } else {
                console.log(`✅ Migrated: ${key} -> ${data.id}`);
                migrationResults.successful++;
            }
            
        } catch (error) {
            console.error(`❌ Failed to migrate ${key}:`, error.message);
            migrationResults.errors.push({
                key,
                error: error.message,
                data: null
            });
            migrationResults.failed++;
        }
    }
    
    return migrationResults;
}

// Rollback function
async function rollbackMigration(backupKey) {
    if (!backupKey) {
        console.error('❌ No backup key provided for rollback');
        return false;
    }
    
    console.log(`🔄 Rolling back migration using backup: ${backupKey}`);
    
    try {
        const backupDataStr = await redis.get(backupKey);
        if (!backupDataStr) {
            console.error('❌ Backup data not found');
            return false;
        }
        
        const backupData = JSON.parse(backupDataStr);
        const restoredCount = Object.keys(backupData).length;
        
        // Restore data to Redis
        for (const [key, data] of Object.entries(backupData)) {
            await redis.hset(key, data);
            await redis.expire(key, 86400 * 30); // 30 days TTL
        }
        
        // Delete from Supabase
        const validationIds = Object.values(backupData).map(record => record.id);
        if (validationIds.length > 0) {
            const { error } = await supabase
                .from('eip_compliance_validations')
                .delete()
                .in('id', validationIds);
            
            if (error) {
                console.error('⚠️ Error deleting from Supabase during rollback:', error.message);
            }
        }
        
        console.log(`✅ Rollback completed: ${restoredCount} records restored to Redis`);
        return true;
        
    } catch (error) {
        console.error('❌ Rollback failed:', error.message);
        return false;
    }
}

// Main migration function
async function runMigration() {
    console.log('🚀 Starting Redis to Supabase compliance data migration...');
    console.log(`   Mode: ${DRY_RUN ? 'DRY RUN' : 'LIVE'}`);
    console.log(`   Batch size: ${MIGRATION_BATCH_SIZE}`);
    console.log(`   Backup enabled: ${BACKUP_REDIS_DATA}`);
    console.log('');
    
    const migrationStartTime = Date.now();
    let backupKey = null;
    
    try {
        // Initialize connections
        await initializeClients();
        
        // Scan Redis data
        const redisScan = await scanRedisComplianceData();
        
        if (redisScan.totalRecords === 0) {
            console.log('✅ No compliance data found in Redis - migration complete');
            return;
        }
        
        // Create backup
        if (BACKUP_REDIS_DATA) {
            backupKey = await backupRedisData(redisScan.validationKeys);
        }
        
        // Process in batches
        console.log(`\n🔄 Starting migration of ${redisScan.totalRecords} records...`);
        
        let totalProcessed = 0;
        let totalSuccessful = 0;
        let totalFailed = 0;
        let allErrors = [];
        
        for (let i = 0; i < redisScan.validationKeys.length; i += MIGRATION_BATCH_SIZE) {
            const batchResult = await migrateBatch(
                redisScan.validationKeys, 
                i, 
                MIGRATION_BATCH_SIZE
            );
            
            totalProcessed += batchResult.processed;
            totalSuccessful += batchResult.successful;
            totalFailed += batchResult.failed;
            allErrors = allErrors.concat(batchResult.errors);
            
            // Progress update
            const progress = (totalProcessed / redisScan.totalRecords * 100).toFixed(1);
            console.log(`📈 Progress: ${progress}% (${totalProcessed}/${redisScan.totalRecords}) - Success: ${totalSuccessful}, Failed: ${totalFailed}`);
        }
        
        // Migration summary
        const migrationTime = Date.now() - migrationStartTime;
        
        console.log('\n' + '='.repeat(60));
        console.log('📊 MIGRATION SUMMARY');
        console.log('='.repeat(60));
        console.log(`Total records scanned: ${redisScan.totalRecords}`);
        console.log(`Records processed: ${totalProcessed}`);
        console.log(`Successfully migrated: ${totalSuccessful}`);
        console.log(`Failed: ${totalFailed}`);
        console.log(`Success rate: ${((totalSuccessful / totalProcessed) * 100).toFixed(1)}%`);
        console.log(`Migration time: ${migrationTime}ms (${(migrationTime / 1000).toFixed(1)}s)`);
        
        if (backupKey) {
            console.log(`Backup key: ${backupKey}`);
        }
        
        if (allErrors.length > 0) {
            console.log(`\n⚠️ Errors encountered: ${allErrors.length}`);
            console.log('First 5 errors:');
            allErrors.slice(0, 5).forEach((error, index) => {
                console.log(`   ${index + 1}. ${error.key}: ${error.error || error.errors?.join(', ')}`);
            });
            
            if (allErrors.length > 5) {
                console.log(`   ... and ${allErrors.length - 5} more errors`);
            }
        }
        
        console.log('\n' + '='.repeat(60));
        
        if (!DRY_RUN && totalFailed > 0) {
            console.log(`\n⚠️ Migration completed with ${totalFailed} failures.`);
            console.log('   You can run the migration again to retry failed records.');
            console.log('   Use ROLLBACK=true to undo the migration if needed.');
        } else if (!DRY_RUN) {
            console.log('\n🎉 Migration completed successfully!');
        } else {
            console.log('\n🔍 DRY RUN completed - no data was actually migrated.');
        }
        
        // Cleanup Redis data after successful migration (optional)
        if (!DRY_RUN && totalFailed === 0 && process.env.COMPLIANCE_MIGRATION_CLEANUP === 'true') {
            console.log('\n🧹 Cleaning up migrated data from Redis...');
            for (const key of redisScan.validationKeys) {
                await redis.del(key);
            }
            console.log('✅ Redis cleanup completed');
        }
        
    } catch (error) {
        console.error('\n❌ Migration failed:', error.message);
        
        if (backupKey && !DRY_RUN) {
            console.log('\n🔄 Rolling back migration due to failure...');
            const rollbackSuccess = await rollbackMigration(backupKey);
            if (rollbackSuccess) {
                console.log('✅ Rollback completed successfully');
            } else {
                console.log('❌ Rollback failed - manual intervention may be required');
            }
        }
        
        process.exit(1);
        
    } finally {
        await closeConnections();
    }
}

// Rollback command
async function runRollback(backupKey) {
    console.log('🔄 Rolling back compliance data migration...');
    
    try {
        await initializeClients();
        
        const success = await rollbackMigration(backupKey);
        
        if (success) {
            console.log('✅ Rollback completed successfully');
        } else {
            console.log('❌ Rollback failed');
            process.exit(1);
        }
        
    } catch (error) {
        console.error('❌ Rollback failed:', error.message);
        process.exit(1);
        
    } finally {
        await closeConnections();
    }
}

// CLI interface
async function main() {
    const args = process.argv.slice(2);
    
    if (args[0] === 'rollback') {
        const backupKey = args[1];
        if (!backupKey) {
            console.error('❌ Usage: node migrate-compliance-data-redis-to-supabase.js rollback <backup-key>');
            process.exit(1);
        }
        await runRollback(backupKey);
    } else {
        await runMigration();
    }
}

// Handle uncaught errors
process.on('unhandledRejection', (reason, promise) => {
    console.error('❌ Unhandled Rejection at:', promise, 'reason:', reason);
    process.exit(1);
});

process.on('uncaughtException', (error) => {
    console.error('❌ Uncaught Exception:', error);
    process.exit(1);
});

// Graceful shutdown
process.on('SIGTERM', () => {
    console.log('\n⚠️ SIGTERM received, shutting down gracefully...');
    closeConnections();
    process.exit(0);
});

process.on('SIGINT', () => {
    console.log('\n⚠️ SIGINT received, shutting down gracefully...');
    closeConnections();
    process.exit(0);
});

// Run the migration
if (require.main === module) {
    main().catch(error => {
        console.error('❌ Migration script failed:', error);
        process.exit(1);
    });
}

module.exports = { runMigration, runRollback, validateComplianceRecord };
