{
  "name": "eip-cr",
  "version": "0.1.0",
  "description": "Educational-IP Content Runtime - AI-powered content generation framework with compliance control",
  "private": true,
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:eip": "jest --config jest.eip.config.js",
    "test:eip:watch": "jest --config jest.eip.config.js --watch",
    "test:eip:coverage": "jest --config jest.eip.config.js --coverage",
    "test:smoke": "jest --config jest.eip.config.js --testNamePattern=\"smoke\"",
    "test:retrieval": "jest --config jest.eip.config.js --testNamePattern=\"retrieval\"",
    "test:auditor": "jest --config jest.eip.config.js --testNamePattern=\"auditor\"",
    "test:db": "jest --config jest.eip.config.js --testNamePattern=\"database\"",
    "test:orchestrator": "jest --config jest.eip.config.js --testNamePattern=\"orchestrator\"",
    "test:ui": "jest --config jest.eip.config.js --testNamePattern=\"review\"",
    "test:integration": "npm run test:retrieval && npm run test:auditor && npm run test:orchestrator",
    "test:performance": "jest --config jest.eip.config.js --testNamePattern=\"Performance\"",
    "test:contracts": "jest --config jest.eip.config.js --testNamePattern=\"Contract\"",
    "test:all": "npm run test:eip && npm run test:integration && npm run test:ui",
    "orchestrator:dev": "tsx watch orchestrator/controller.ts",
    "orchestrator:start": "tsx orchestrator/controller.ts",
    "ip:validate": "npx tsx --no-cache scripts/validate-ips.ts",
    "compliance:check": "tsx scripts/compliance-check.ts",
    "db:setup": "tsx db/setup.ts",
    "db:seed": "tsx db/seed.ts",
    "db:migrate": "npm run db:setup",
    "db:migration:new": "echo 'Creating new migration - use: supabase migration new <migration_name>'",
    "db:mirror": "tsx scripts/mirror-to-neo4j.ts",
    "review:validate": "tsx scripts/validate-review-ui.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.27",
    "@ai-sdk/openai": "^2.0.44",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/supabase-js": "^2.57.4",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "ai": "^5.0.60",
    "autoprefixer": "^10.4.20",
    "bullmq": "^5.61.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.8.1",
    "jose": "^6.1.0",
    "lucide-react": "^0.545.0",
    "next": "^14.2.32",
    "nunjucks": "^3.2.4",
    "postcss": "^8.4.49",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.53.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "uuid": "^13.0.0",
    "winston": "^3.8.2",
    "yaml": "^2.6.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.0.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0",
    "supabase": "^2.15.4",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "vitest": "^3.2.4"
  }
}
