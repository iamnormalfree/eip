    echo -n "  HOOK_AGENT_PROMPT: "
    modified_cmd=$(HOOK_AGENT_PROMPT 2 "test command")
    if [[ "$modified_cmd" == "test command" ]]; then
        echo -e "${GREEN}✓${NC} (passes through by default)"
