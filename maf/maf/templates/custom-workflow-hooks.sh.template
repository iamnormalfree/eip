    if HOOK_AFTER_CHECK 1 '[1,2]'; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
    fi

    echo -n "  HOOK_ERROR_HANDLER: "
    if HOOK_ERROR_HANDLER 42 "test error" "test context"; then
        echo -e "${YELLOW}!${NC} (returned recovery attempt)"
    else
