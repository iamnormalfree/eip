    if HOOK_CUSTOM_BEAD "123" "Test Bead" '["test"]'; then
        echo -e "${YELLOW}!${NC} (hook handled bead)"
    else
        exit_code=$?
        if [[ $exit_code -eq 1 ]]; then
            echo -e "${GREEN}✓${NC} (uses default assignment)"
        else
            echo -e "${RED}✗${NC} (unexpected exit code: $exit_code)"
        fi
