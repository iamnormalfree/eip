#!/bin/bash
# custom-preflight-checks.sh - Custom preflight validation checks for your franchisee
#
# ABOUT THIS TEMPLATE:
#   This file is a template for adding franchisee-specific preflight checks.
#   Copy this file to .maf/config/custom-preflight-checks.sh and customize it
#   for your project's needs.
#
# USAGE:
#   1. Copy this template to .maf/config/custom-preflight-checks.sh
#   2. Customize the custom_preflight_checks() function below
#   3. Make the file executable: chmod +x .maf/config/custom-preflight-checks.sh
#   4. The preflight-gatekeeper.sh will automatically source and run your checks
#
# INTEGRATION:
#   The preflight-gatekeeper.sh (maf/scripts/maf/preflight-gatekeeper.sh) will:
#   - Check if .maf/config/custom-preflight-checks.sh exists
#   - Source it if found
#   - Call custom_preflight_checks() function if defined
#   - Your checks run AFTER all standard MAF preflight checks complete
#
# EXIT CODES:
#   0 - All custom checks passed
#   1 - Critical custom check failed (blocks execution)
#   2 - System error (missing dependency, invalid environment)
#
# ENVIRONMENT VARIABLES:
#   MAF_SKIP_PREFLIGHT - Set to 'true' to skip all preflight checks (including custom)
#   PROJECT_ROOT - Project root directory (auto-detected by preflight-gatekeeper.sh)
#   TOPOLOGY_FILE - Path to agent topology file (auto-detected)
#
# ERROR HANDLING:
#   Use these functions from preflight-gatekeeper.sh in your custom checks:
#   - return_error "Error message" "Fix hint"  (critical, exits with code 1)
#   - return_warn "Warning message" "Fix hint" (advisory, continues execution)
#   - return_skip "Skip message"               (informational, continues execution)
#
# BEST PRACTICES:
#   - Keep checks fast (under 5 seconds total)
#   - Use return_warn() for advisory checks that shouldn't block execution
#   - Use return_error() only for critical issues that must block execution
#   - Provide clear, actionable fix hints
#   - Test your checks in isolation before deploying
#   - Document what each check validates and why it matters
#

set -euo pipefail

# Colors for output (imported from preflight-gatekeeper.sh)
