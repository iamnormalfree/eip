# ============================================================================
# SCRIPT ENTRY POINT
# ============================================================================

# Only run custom_preflight_checks() if this script is executed directly
# (not when sourced by preflight-gatekeeper.sh)
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    # Set up environment variables if not already set
    PROJECT_ROOT="${PROJECT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
    TOPOLOGY_FILE="${TOPOLOGY_FILE:-${PROJECT_ROOT}/.maf/config/agent-topology.json}"

    # Import error handling functions from preflight-gatekeeper.sh if available
    gatekeeper_path="${PROJECT_ROOT}/maf/scripts/maf/preflight-gatekeeper.sh"
    if [[ ! -f "$gatekeeper_path" ]]; then
        gatekeeper_path="${PROJECT_ROOT}/scripts/maf/preflight-gatekeeper.sh"
    fi

    if [[ -f "$gatekeeper_path" ]]; then
        # Source only the error handling functions
        source "$gatekeeper_path"
    else
        # Fallback error handling functions if gatekeeper not found
        return_error() {
            echo -e "${RED}ERROR: ${1}${NC}" >&2
            echo -e "${YELLOW}FIX: ${2}${NC}" >&2
            exit 1
        }
        return_warn() {
            echo -e "${YELLOW}WARNING: ${1}${NC}"
            echo -e "${YELLOW}HINT: ${2}${NC}"
        }
        return_skip() {
            echo -e "${BLUE}SKIP: ${1}${NC}"
        }
    fi

    # Run custom preflight checks
    custom_preflight_checks
fi
