// ABOUTME: Review API endpoints - Handle approve/reject actions for artifacts
// ABOUTME: Updates artifact status and stores brand profile feedback

import { NextRequest, NextResponse } from 'next/server';
import { getSupabaseAdmin } from '../../../../lib_supabase/db/supabase-client';
import { Database } from '../../../../lib_supabase/db/types/database.types';

type EipArtifact = Database['public']['Tables']['eip_artifacts']['Row'];
type EipBrandProfile = Database['public']['Tables']['eip_brand_profiles']['Row'];

export async function POST(request: NextRequest) {
  try {
    const supabase = getSupabaseAdmin();
    const body = await request.json();

    const { artifactId, action, feedback } = body;

    if (!artifactId || !action || !['approve', 'reject'].includes(action)) {
      return NextResponse.json(
        { error: 'Missing required fields: artifactId and action (approve/reject)' },
        { status: 400 }
      );
    }

    // Update artifact status
    const newStatus = action === 'approve' ? 'published' : 'rejected';
    const { data: artifact, error: updateError } = await supabase
      .from('eip_artifacts')
      .update({
        status: newStatus,
        updated_at: new Date().toISOString()
      })
      .eq('id', artifactId)
      .select()
      .single();

    if (updateError) {
      console.error('Error updating artifact status:', updateError);
      return NextResponse.json(
        { error: 'Failed to update artifact status' },
        { status: 500 }
      );
    }

    // Store brand profile feedback if provided
    if (feedback && artifact) {
      const brandProfileData: Partial<EipBrandProfile> = {
        brand: 'eip_reviewer', // Default brand for reviewer feedback
        version: '1.0',
        profile_json: {
          artifact_id: artifactId,
          action,
          feedback,
          reviewer_timestamp: new Date().toISOString(),
          artifact_metadata: {
            frontmatter: artifact.frontmatter,
            ledger: artifact.ledger
          }
        },
        updated_at: new Date().toISOString()
      };

      const { error: feedbackError } = await supabase
        .from('eip_brand_profiles')
        .insert(brandProfileData);

      if (feedbackError) {
        console.error('Error storing brand profile feedback:', feedbackError);
        // Don't fail the request if feedback storage fails, but log it
      }
    }

    return NextResponse.json({
      success: true,
      artifactId,
      action,
      status: newStatus
    });

  } catch (error) {
    console.error('Error in review API:', error);
    return NextResponse.json(
      { error: 'Internal server error' },
      { status: 500 }
    );
  }
}

// GET endpoint to fetch a specific artifact for review
export async function GET(request: NextRequest) {
  try {
    const supabase = getSupabaseAdmin();
    const { searchParams } = new URL(request.url);
    const artifactId = searchParams.get('artifactId');

    if (!artifactId) {
      return NextResponse.json(
        { error: 'Missing artifactId parameter' },
        { status: 400 }
      );
    }

    const { data: artifact, error } = await supabase
      .from('eip_artifacts')
      .select('*')
      .eq('id', artifactId)
      .single();

    if (error) {
      console.error('Error fetching artifact:', error);
      return NextResponse.json(
        { error: 'Artifact not found' },
        { status: 404 }
      );
    }

    return NextResponse.json({ artifact });

  } catch (error) {
    console.error('Error fetching artifact:', error);
    return NextResponse.json(
      { error: 'Internal server error' },
      { status: 500 }
    );
  }
}